rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: production
    // Fields:
    //   - productionDate: string (required)
    //   - shift: string (required, enum: Day, Night)
    //   - machineNo: string (required)
    //   - operatorId: string (required)
    //   - model: string (required)
    //   - productionQty: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: wastage
    // Fields:
    //   - date: string (required)
    //   - shift: string (required)
    //   - machineNo: string (required)
    //   - unit: string (required)
    //   - setupDamage: number
    //   - printDamage: number
    //   - cornerCut: number
    //   - cuttingDamage: number
    //   - extruderDamage: number
    //   - bobinCut: number
    //   - ultrasonicProblem: number
    //   - hookDamage: number
    //   - sampleWastage: number
    //   - createdAt: timestamp (required)
    //
    // Collection: breakdown
    // Fields:
    //   - date: string (required)
    //   - shift: string (required)
    //   - machineNo: string (required)
    //   - sizeChange: number
    //   - rollChange: number
    //   - waitingForJob: number
    //   - noOperator: number
    //   - powerCut: number
    //   - machineBreakdown: number
    //   - airProblem: number
    //   - qualityChecked: number
    //   - sampleProductionTime: string
    //   - createdAt: timestamp (required)
    //
    // Collection: units
    // Fields:
    //   - name: string (required)
    //
    // Collection: machines, operators, pendingOrders
    // Master data collections.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return true; // Public access allowed for now
    }

    function isAdmin() {
      return true; // Public access allowed for now
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidProduction(data) {
      return data.productionDate is string &&
             data.shift in ['Day', 'Night'] &&
             data.machineNo is string &&
             data.operatorId is string &&
             data.model is string &&
             data.productionQty is number &&
             data.productionQty >= 0;
    }

    function isValidWastage(data) {
      return data.date is string &&
             data.shift in ['Day', 'Night'] &&
             data.machineNo is string &&
             data.unit is string &&
             data.setupDamage is number &&
             data.printDamage is number &&
             data.cornerCut is number &&
             data.cuttingDamage is number &&
             data.extruderDamage is number &&
             data.bobinCut is number &&
             data.ultrasonicProblem is number &&
             data.hookDamage is number &&
             data.sampleWastage is number;
    }

    function isValidBreakdown(data) {
      return data.date is string &&
             data.shift in ['Day', 'Night'] &&
             data.machineNo is string &&
             data.sizeChange is number &&
             data.rollChange is number &&
             data.waitingForJob is number &&
             data.noOperator is number &&
             data.powerCut is number &&
             data.machineBreakdown is number &&
             data.airProblem is number &&
             data.qualityChecked is number &&
             data.sampleProductionTime is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Production Entries
    match /production/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['productionDate', 'shift', 'machineNo', 'operatorId', 'model', 'productionQty', 'createdAt']) && isValidProduction(request.resource.data);
      allow update: if isAuthenticated() && isValidProduction(request.resource.data);
      allow delete: if isAdmin();
    }

    // Wastage Entries
    match /wastage/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['date', 'shift', 'machineNo', 'unit', 'createdAt']) && isValidWastage(request.resource.data);
      allow update: if isAuthenticated() && isValidWastage(request.resource.data);
      allow delete: if isAdmin();
    }

    // Breakdown Entries
    match /breakdown/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['date', 'shift', 'machineNo', 'createdAt']) && isValidBreakdown(request.resource.data);
      allow update: if isAuthenticated() && isValidBreakdown(request.resource.data);
      allow delete: if isAdmin();
    }

    // Master Data (Machines, Operators, PendingOrders, Units)
    match /machines/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /operators/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /pendingOrders/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /units/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Connection Test Collection
    match /test/{id} {
      allow read: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions (Public access allowed)
    function isAuthenticated() { return true; }
    function isAdmin() { return true; }

    // Production, Wastage, and Breakdown Entries
    match /production/{id} { allow read, write: if true; }
    match /wastage/{id} { allow read, write: if true; }
    match /breakdown/{id} { allow read, write: if true; }
    
    // Master Data
    match /machines/{id} { allow read, write: if true; }
    match /operators/{id} { allow read, write: if true; }
    match /pendingOrders/{id} { allow read, write: if true; }
    
    // --- ADD THIS LINE TO SOLVE MASTER UNIT ---
    match /units/{id} { allow read, write: if true; }
    // ------------------------------------------

    // Roll Entries
    match /rolls/{id} { allow read, write: if true; }

    // Target Entries
    match /targets/{id} { allow read, write: if true; }

    // Connection Test
    match /test/{id} { allow read: if true; }

    // Default deny for everything else
    match /{document=**} { allow read, write: if false; }
  }
}

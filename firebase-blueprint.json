{
  "entities": {
    "ProductionEntry": {
      "title": "Production Entry",
      "description": "Record of daily production activity.",
      "type": "object",
      "properties": {
        "productionDate": { "type": "string", "format": "date", "description": "Date of production." },
        "shift": { "type": "string", "enum": ["Day", "Night"], "description": "Shift of production." },
        "machineNo": { "type": "string", "description": "Machine identifier." },
        "operatorId": { "type": "string", "description": "Operator identifier." },
        "piNo": { "type": "string", "description": "Production Instruction number." },
        "model": { "type": "string", "description": "Model identifier." },
        "description": { "type": "string", "description": "Description of the model." },
        "material": { "type": "string", "description": "Material used." },
        "thickness": { "type": "string", "description": "Thickness of the material." },
        "productionQty": { "type": "number", "description": "Quantity produced." },
        "packetQty": { "type": "number", "description": "Number of packets." },
        "meter": { "type": "number", "description": "Total meters produced." },
        "rollKgs": { "type": "number", "description": "Weight of the roll in Kgs." },
        "rollId": { "type": "string", "description": "Roll identifier." },
        "rollQty": { "type": "number", "description": "Quantity per roll." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when record was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when record was last updated." }
      },
      "required": ["productionDate", "shift", "machineNo", "operatorId", "model", "productionQty"]
    },
    "WastageEntry": {
      "title": "Wastage Entry",
      "description": "Record of material wastage.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "Date of wastage." },
        "shift": { "type": "string", "enum": ["Day", "Night"], "description": "Shift of wastage." },
        "machineNo": { "type": "string", "description": "Machine identifier." },
        "unit": { "type": "string", "description": "Unit identifier." },
        "setupDamage": { "type": "number", "description": "Setup damage." },
        "printDamage": { "type": "number", "description": "Print damage." },
        "cornerCut": { "type": "number", "description": "Corner cut." },
        "cuttingDamage": { "type": "number", "description": "Cutting damage." },
        "extruderDamage": { "type": "number", "description": "Extruder damage." },
        "bobinCut": { "type": "number", "description": "Bobin cut." },
        "ultrasonicProblem": { "type": "number", "description": "Ultrasonic problem." },
        "hookDamage": { "type": "number", "description": "Hook damage." },
        "sampleWastage": { "type": "number", "description": "Sample wastage." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when record was created." }
      },
      "required": ["date", "shift", "machineNo", "unit", "createdAt"]
    },
    "BreakdownEntry": {
      "title": "Breakdown Entry",
      "description": "Record of machine breakdown.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "Date of breakdown." },
        "shift": { "type": "string", "enum": ["Day", "Night"], "description": "Shift of breakdown." },
        "machineNo": { "type": "string", "description": "Machine identifier." },
        "unit": { "type": "string", "description": "Unit identifier." },
        "sizeChange": { "type": "number", "description": "Time spent on size change." },
        "rollChange": { "type": "number", "description": "Time spent on roll change." },
        "waitingForJob": { "type": "number", "description": "Time spent waiting for job." },
        "noOperator": { "type": "number", "description": "Time spent with no operator." },
        "powerCut": { "type": "number", "description": "Time spent on power cut." },
        "machineBreakdown": { "type": "number", "description": "Time spent on machine breakdown." },
        "airProblem": { "type": "number", "description": "Time spent on air problem." },
        "qualityChecked": { "type": "number", "description": "Time spent on quality checked." },
        "sampleProductionTime": { "type": "string", "description": "Sample production time." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when record was created." }
      },
      "required": ["date", "shift", "machineNo", "unit", "createdAt"]
    },
    "Machine": {
      "title": "Machine",
      "description": "Machine master data.",
      "type": "object",
      "properties": {
        "machineNo": { "type": "string", "description": "Machine identifier." }
      },
      "required": ["machineNo"]
    },
    "Operator": {
      "title": "Operator",
      "description": "Operator master data.",
      "type": "object",
      "properties": {
        "operatorId": { "type": "string", "description": "Operator identifier." }
      },
      "required": ["operatorId"]
    },
    "PendingOrder": {
      "title": "Pending Order",
      "description": "Pending order master data.",
      "type": "object",
      "properties": {
        "piNo": { "type": "string", "description": "PI number." },
        "model": { "type": "string", "description": "Model identifier." },
        "description": { "type": "string", "description": "Description of the model." },
        "cylinderSizeMM": { "type": "number", "description": "Cylinder size in MM." }
      },
      "required": ["piNo", "model"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Unit master data.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the unit." }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/production": { "schema": { "$ref": "ProductionEntry" }, "description": "Collection of production entries." },
    "/wastage": { "schema": { "$ref": "WastageEntry" }, "description": "Collection of wastage entries." },
    "/breakdown": { "schema": { "$ref": "BreakdownEntry" }, "description": "Collection of breakdown entries." },
    "/machines": { "schema": { "$ref": "Machine" }, "description": "Collection of machines." },
    "/operators": { "schema": { "$ref": "Operator" }, "description": "Collection of operators." },
    "/pendingOrders": { "schema": { "$ref": "PendingOrder" }, "description": "Collection of pending orders." },
    "/units": { "schema": { "$ref": "Unit" }, "description": "Collection of units." }
  }
}
